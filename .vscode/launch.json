{
  // Use IntelliSense to learn about possible Node.js debug attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "St Extension",
      "type": "extensionHost",
      "request": "launch",
      "sourceMaps": true,
      "args": [
        "${workspaceFolder}/src/plc/workspace",
        "--extensionDevelopmentPath=${workspaceFolder}/src/plc/extension"
      ],
      "outFiles": [
        "${workspaceRoot}/src/plc/extension/dist/st-extension.cjs",
        "${workspaceFolder}/src/plc/langium-server/out/main.cjs",
      ],
     
    },
    {
      "name": "Attach to Language Server",
      "type": "node",
      "port": 6009,
      "request": "attach",
      "skipFiles": [
          "<node_internals>/**"
      ],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceRoot}/src/plc/langium-server/out/**/*.js",
          "${workspaceFolder}/node_modules/langium/**/*.js"
      ]
  },
  ],
 
}
