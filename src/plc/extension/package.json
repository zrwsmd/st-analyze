{
  "name": "st-plugin",
  "displayName": "ST plugin",
  "version": "2.0.0",
  "private": "true",
  "description": "An example graphical language used for modeling workflows",
  "categories": [
    "Programming Languages"
  ],
  "homepage": "https://www.eclipse.org/glsp/",
  "bugs": "https://github.com/eclipse-glsp/glsp/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/eclipse-glsp/glsp-vscode-integration.git"
  },
  "author": {
    "name": "EclipseGLSP"
  },
  "contributors": [
    {
      "name": "Eclipse GLSP Project",
      "email": "glsp-dev@eclipse.org",
      "url": "https://projects.eclipse.org/projects/ecd.glsp"
    }
  ],
  "publisher": "Eclipse-GLSP",
  "type": "module",
  "main": "./dist/st-extension.cjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && node esbuild.mjs",
    "bundle": "webpack",
    "bundle:prod": "webpack --config ./webpack.prod.js",
    "clean": "rimraf lib tsconfig.tsbuildinfo dist",
    "lint": "eslint --ext .ts,.tsx ./src",
    "lint:ci": "yarn lint -o eslint.xml -f checkstyle",
    "package": "vsce package --yarn",
    "prepare": "yarn clean && yarn build",
    "watch": "tsc -w"
  },
  "contributes": {
    "commands": [
      {
        "command": "exportAllDeclInfo",
        "title": "exportAllDeclInfo"
      },
      {
        "command": "getRelatedElementInfo",
        "title": "getRelatedElementInfo"
      }
    ],
    "customEditors": [],
    "keybindings": [],
    "menus": {
      "editor/title": []
    },
    "submenus": [
      {
        "id": "workflow.editor.title",
        "label": "Diagram"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:st",
    "onStartupFinished"
  ],
  "dependencies": {
    "@types/lodash": "^4.14.202",
    "@types/multimap": "~1.1.4",
    "node-ipc": "^11.1.0"
  },
  "devDependencies": {
    "@eclipse-glsp/vscode-integration": "~2.1.1",
    "@vscode/vsce": "^2.19.0",
    "copy-webpack-plugin": "^11.0.0",
    "ts-loader": "^9.4.4",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-merge": "^5.9.0"
  },
  "engines": {
    "vscode": "^1.54.0"
  }
}
